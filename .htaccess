# ==========================================================================
# .htaccess — BBB Starter
# Security headers, caching, clean URLs, WebP auto-serve, dev-mode settings
# ==========================================================================

# --------------------------------------------------------------------------
# Force HTTPS (Cloudflare-safe)
# --------------------------------------------------------------------------
RewriteEngine On

RewriteCond %{HTTP:X-Forwarded-Proto} !https
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# --------------------------------------------------------------------------
# www Canonicalization
# Uncomment ONE block below. Delete the other.
# --------------------------------------------------------------------------

# Option A: Redirect non-www to www
# RewriteCond %{HTTP_HOST} !^www\. [NC]
# RewriteRule ^(.*)$ https://www.%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Option B: Redirect www to non-www
# RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
# RewriteRule ^(.*)$ https://%1%{REQUEST_URI} [L,R=301]

# --------------------------------------------------------------------------
# Clean URLs — Remove .php extension
# Exceptions: git-deploy.php (webhook needs exact filename)
# --------------------------------------------------------------------------
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} !^/git-deploy\.php
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^(.*)$ $1.php [L]

# --------------------------------------------------------------------------
# Custom Error Pages
# --------------------------------------------------------------------------
ErrorDocument 404 /404.php

# --------------------------------------------------------------------------
# Directory Listing Disabled
# --------------------------------------------------------------------------
Options -Indexes

# --------------------------------------------------------------------------
# Security Headers
# --------------------------------------------------------------------------
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"

  # HSTS — DEV MODE: short max-age for testing
  # AT LAUNCH: change to max-age=31536000
  Header set Strict-Transport-Security "max-age=300"
</IfModule>

# --------------------------------------------------------------------------
# Content Security Policy (COMMENTED OUT — configure per project)
#
# Uncomment and adjust for your project's third-party resources.
# Common additions:
#   Google Fonts: fonts.googleapis.com fonts.gstatic.com
#   Google Analytics: www.googletagmanager.com
#   MachForm: *.forms-db.com assets.forms-db.com
#   Enzuzo: app.enzuzo.com
# --------------------------------------------------------------------------
# <IfModule mod_headers.c>
#   Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https:; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' https://www.google-analytics.com; frame-src 'self' https://*.forms-db.com"
# </IfModule>

# --------------------------------------------------------------------------
# Sensitive File Protection
# --------------------------------------------------------------------------
<FilesMatch "^\.git|\.htaccess|\.env|business-config\.php">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
  </IfModule>
</FilesMatch>

# --------------------------------------------------------------------------
# Block access to /build/ directory
# --------------------------------------------------------------------------
RedirectMatch 403 ^/build/

# --------------------------------------------------------------------------
# WebP Auto-Serve
# Serves .webp version when browser supports it and file exists.
# Keep original JPG/PNG files — .htaccess handles the swap.
# --------------------------------------------------------------------------
<IfModule mod_rewrite.c>
  RewriteCond %{HTTP_ACCEPT} image/webp
  RewriteCond %{REQUEST_FILENAME} \.(jpe?g|png)$
  RewriteCond %{REQUEST_FILENAME}\.webp -f
  RewriteRule ^(.+)\.(jpe?g|png)$ $1.$2.webp [T=image/webp,L]
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(jpe?g|png)\.webp$">
    Header set Vary "Accept"
  </FilesMatch>
</IfModule>

AddType image/webp .webp

# --------------------------------------------------------------------------
# Gzip Compression
# --------------------------------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
  AddOutputFilterByType DEFLATE text/javascript application/javascript application/json
  AddOutputFilterByType DEFLATE image/svg+xml application/xml
  AddOutputFilterByType DEFLATE application/font-woff application/font-woff2
</IfModule>

# --------------------------------------------------------------------------
# Browser Caching
# --------------------------------------------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault "access plus 2 hours"

  # DEV MODE: HTML set to 0 seconds — no caching during development
  # AT LAUNCH: change to "access plus 1 hour"
  ExpiresByType text/html "access plus 0 seconds"

  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
</IfModule>
